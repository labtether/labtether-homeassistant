{
  "name": "LabTether",
  "slug": "labtether",
  "description": "LabTether hub runtime for Home Assistant environments.",
  "version": "1.2.0",
  "stage": "experimental",
  "arch": ["aarch64", "amd64"],
  "startup": "services",
  "boot": "auto",
  "init": false,
  "host_network": false,
  "ingress": false,
  "ingress_port": 8080,
  "ports_description": {
    "8080/tcp": "LabTether HTTP API",
    "8443/tcp": "LabTether HTTPS API (auto/external TLS mode)"
  },
  "ports": {
    "8080/tcp": 8080,
    "8443/tcp": 8443
  },
  "map": ["config:rw", "ssl:rw", "share:rw"],
  "options": {
    "labtether_owner_token": "",
    "labtether_admin_password": "",
    "encryption_key": "",
    "database_url": "",
    "tls_mode": "auto",
    "auto_generate_credentials": true
  },
  "schema": {
    "labtether_owner_token": "str?",
    "labtether_admin_password": "str?",
    "encryption_key": "str?",
    "database_url": "str?",
    "tls_mode": "list(auto|external|disabled)",
    "auto_generate_credentials": "bool"
  }
}
